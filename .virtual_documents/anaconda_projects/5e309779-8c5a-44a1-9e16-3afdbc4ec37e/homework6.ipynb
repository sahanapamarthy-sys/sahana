import numpy as np


list = [20, 27, 9, 12, 31, 17, 4, 50, 39, 35]
arr = np.array(list)


multiply = arr *4
print("Arr multiplied by 4:", multiply)


print ("Mean: ",np.mean(arr))


print ("Median: ",np.median(arr))


print ("standard Deviation: ",np.std(arr))


min_num= np.argmin(arr)
max_num = np.argmax(arr)
print("Index of smallest value:", min_num)
print("Index of largest value:", max_num)


print("Smallest value (using index):", arr[min_num])
print("Largest value (using index):", arr[max_num])



print("Minimum value:", np.min(arr))
print("Maximum value:", np.max(arr))


print("Do they match?",arr[min_num] == np.min(arr) and arr[max_num] == np.max(arr))



greater_20 = arr[arr > 20]
